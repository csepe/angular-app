.container 

    textarea.editor(matInput, placeholder="String", [(ngModel)]="text", name="text", spellcheck="false", (ngModelChange)="textChanged()")
    
    .controls
        button(
            mat-raised-button, 
            color="primary", 
            *ngFor="let control of controls", 
            (click)="runCmd(control.cmd)"
        ) {{control.name}}